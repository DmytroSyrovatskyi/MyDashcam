<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#1AFFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="54dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#2A2A2A">

            <ImageView
                android:id="@+id/imgThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_play"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                app:tint="#B3FFFFFF" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/textVideoDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="08 May, 02:37"
                android:fontFamily="sans-serif-medium"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/textVideoInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="10 min • 1.2 GB"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:textColor="#B3B3B3" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnLockUnlock"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_lock_file"
            app:tint="#FFC107"
            android:src="@android:drawable/ic_secure"
            tools:ignore="ImageContrastCheck" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_delete"
            app:tint="#FF5252"
            android:src="@android:drawable/ic_menu_delete"
            tools:ignore="ImageContrastCheck" />

    </LinearLayout>
</androidx.cardview.widget.CardView>