<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ui_background">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/ui_surface"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_active"
                android:contentDescription="@string/desc_back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/desc_trip_journal"
                android:textColor="@color/text_active"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <ImageButton
                android:id="@+id/btnImport"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_add"
                app:tint="#42A5F5"
                android:contentDescription="@string/desc_import" />

            <ImageButton
                android:id="@+id/btnExport"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_save"
                app:tint="#66BB6A"
                android:contentDescription="@string/desc_export" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btnToday"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:backgroundTint="#333333"
            android:textColor="@color/text_active"
            android:textSize="12sp"
            android:text="@string/filter_today"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck" />

        <Button
            android:id="@+id/btnWeek"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:backgroundTint="#333333"
            android:textColor="@color/text_active"
            android:textSize="12sp"
            android:text="@string/filter_week"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck" />

        <Button
            android:id="@+id/btnMonth"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:backgroundTint="#333333"
            android:textColor="@color/text_active"
            android:textSize="12sp"
            android:text="@string/filter_month"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck" />

        <Button
            android:id="@+id/btnCalendar"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:backgroundTint="#333333"
            android:textColor="@color/text_active"
            android:textSize="14sp"
            android:text="@string/filter_calendar"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="@string/desc_trip_journal">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />
    </ScrollView>
</LinearLayout>