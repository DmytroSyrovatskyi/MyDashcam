<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:contentDescription="@string/desc_back" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/desc_trip_journal"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <ImageButton
            android:id="@+id/btnCloudSync"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_sync"
            app:tint="#00E5FF"
            android:contentDescription="@string/desc_cloud_sync" />

        <ImageButton
            android:id="@+id/btnImport"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_add"
            app:tint="#B3B3B3"
            android:contentDescription="@string/desc_import" />

        <ImageButton
            android:id="@+id/btnExport"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_save"
            app:tint="#B3B3B3"
            android:contentDescription="@string/desc_export" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_segmented_track"
        android:padding="4dp"
        android:orientation="horizontal"
        tools:ignore="ButtonStyle">

        <Button
            android:id="@+id/btnToday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="42dp"
            android:background="@drawable/selector_segmented_bg"
            app:backgroundTint="@null"
            android:textColor="@color/selector_segmented_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="@string/filter_today"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck,ButtonStyle" />

        <Button
            android:id="@+id/btnWeek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="42dp"
            android:background="@drawable/selector_segmented_bg"
            app:backgroundTint="@null"
            android:textColor="@color/selector_segmented_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="@string/filter_week"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck,ButtonStyle" />

        <Button
            android:id="@+id/btnMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="42dp"
            android:background="@drawable/selector_segmented_bg"
            app:backgroundTint="@null"
            android:textColor="@color/selector_segmented_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="@string/filter_month"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck,ButtonStyle" />

        <Button
            android:id="@+id/btnAllTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="42dp"
            android:background="@drawable/selector_segmented_bg"
            app:backgroundTint="@null"
            android:textColor="@color/selector_segmented_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="@string/filter_all"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck,ButtonStyle" />

        <Button
            android:id="@+id/btnCalendar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:minHeight="42dp"
            android:background="@drawable/selector_segmented_bg"
            app:backgroundTint="@null"
            android:textColor="@color/selector_segmented_text"
            android:textSize="14sp"
            android:text="@string/filter_calendar"
            tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck,ButtonStyle" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:contentDescription="@string/desc_trip_journal">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="48dp" />
    </androidx.core.widget.NestedScrollView>

</LinearLayout>